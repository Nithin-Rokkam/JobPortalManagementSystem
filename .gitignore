# =============================================================
# JOBLIX — JPMS .gitignore
# Covers: Spring Boot microservices + Angular frontend + Docker
# =============================================================


# =============================================================
# SECRETS & ENVIRONMENT — NEVER COMMIT THESE
# =============================================================
.env
.env.*
*.env
secrets/
credentials/


# =============================================================
# OS GENERATED FILES
# =============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini


# =============================================================
# IDE — ECLIPSE / STS
# =============================================================
.metadata/
.apt_generated/
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache/
*.launch
RemoteSystemsTempFiles/
.recommenders/


# =============================================================
# IDE — INTELLIJ IDEA
# =============================================================
.idea/
*.iws
*.iml
*.ipr
out/


# =============================================================
# IDE — VS CODE
# =============================================================
# Keep workspace-specific settings but ignore personal/generated ones
.vscode/settings.json
.history/


# =============================================================
# IDE — SONARLINT
# =============================================================
.sonarlint/


# =============================================================
# JAVA / MAVEN BUILD OUTPUT
# =============================================================
target/
build/
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/

# Compiled class files
*.class

# Maven wrapper binary (generated on first build, not needed in VCS)
.mvn/wrapper/maven-wrapper.jar

# Maven wrapper properties (keep — defines Maven version)
# !.mvn/wrapper/maven-wrapper.properties

# JAR/WAR/EAR artifacts
*.jar
*.war
*.ear
*.nar

# Except Maven wrapper jar (already excluded above via .mvn/)
# and any intentional lib jars placed in src/main/resources

# Surefire / Failsafe test reports
**/surefire-reports/
**/failsafe-reports/

# JaCoCo coverage reports
**/jacoco.exec
**/jacoco-report/
jacoco-aggregator/target/


# =============================================================
# SPRING BOOT — RUNTIME ARTIFACTS
# =============================================================
# Application log files generated by Log4j2 rolling appender
logs/
*.log
*.log.gz
*.log.zip

# Spring Boot DevTools restart trigger
.reloadtrigger


# =============================================================
# NODE / ANGULAR FRONTEND
# =============================================================
jpms-frontend/node_modules/
jpms-frontend/dist/
jpms-frontend/.angular/cache/
jpms-frontend/tmp/
jpms-frontend/out-tsc/
jpms-frontend/bazel-out/

# npm / yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Angular test / coverage output
jpms-frontend/coverage/
jpms-frontend/__screenshots__/
jpms-frontend/testem.log
jpms-frontend/.sass-cache/
jpms-frontend/connect.lock
jpms-frontend/libpeerconnection.log

# TypeScript incremental compilation cache
*.tsbuildinfo


# =============================================================
# DOCKER
# =============================================================
# Local override files (contain machine-specific or secret config)
docker-compose.override.yml
docker-compose.local.yml

# Docker build context artifacts
.dockerignore.local


# =============================================================
# TEMPORARY & EDITOR SWAP FILES
# =============================================================
*.tmp
*.temp
*.swp
*.swo
*~
*.bak
*.orig


# =============================================================
# DATABASE — LOCAL FILES
# =============================================================
# Ignore local DB dumps but NOT migration scripts in src/
*.db
*.sqlite
*.sqlite3
# Scoped dump files only — do NOT ignore src/**/*.sql (Flyway/Liquibase)
dump.sql
*-dump.sql
*_dump.sql
backup.sql


# =============================================================
# CERTIFICATES & KEYS
# =============================================================
*.pem
*.key
*.p12
*.jks
*.keystore
*.truststore


# =============================================================
# MISCELLANEOUS
# =============================================================
# Patch files
*.patch
*.diff

# Archive files (generated artifacts)
*.zip
*.tar.gz
*.tgz
*.rar

# Python (if any tooling scripts exist)
__pycache__/
*.pyc
*.pyo
.venv/
